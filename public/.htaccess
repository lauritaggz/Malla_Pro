# Bluehost / cPanel / Apache — SPA (React Router + Vite)
#
# Tras `npm run build`, sube TODO el contenido de dist/ a la raíz del dominio
# (ej. public_html/mallapro.cl si el dominio apunta ahí). Activa "mostrar archivos
# ocultos" en el administrador de archivos: .htaccess debe subirse sí o sí.
#
# Si la app vive en subcarpeta (ej. tudominio.com/malla/), en vite.config.js pon
# base: "/malla/" y aquí descomenta y ajusta RewriteBase:
#   RewriteBase /malla/

DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No reescribir archivos ni directorios reales (assets, /mallas/*.json, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

# Caché larga para assets con hash (Vite emite nombres versionados en /assets/)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>
